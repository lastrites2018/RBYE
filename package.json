{
  "name": "RBYE",
  "version": "0.0.1",
  "scripts": {
    "dev": "bash scripts/run-next.sh dev",
    "build": "bash scripts/run-next.sh build",
    "postbuild": "next-sitemap -c next-sitemap.config.js",
    "start": "bash scripts/run-next.sh start",
    "dev:all": "RBYE_AUTO_KILL=1 RBYE_API_WATCH=0 RBYE_AUTOSCAN=0 RBYE_API_PORT=5003 RBYE_FRONTEND_PORT=5004 bash scripts/dev-local.sh",
    "stage": "pnpm build && pnpm start",
    "type-check": "tsc",
    "test": "bun test"
  },
  "packageManager": "pnpm@10.5.2",
  "dependencies": {
    "date-fns": "2.30.0",
    "next": "16.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-highlight-words": "0.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "autoprefixer": "^10.4.14",
    "next-sitemap": "^4.2.3",
    "playwright": "^1.58.2",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.4.31"
    }
  },
  "license": "ISC"
}
